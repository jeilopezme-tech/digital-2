# ============================================================
# colorlight_i9.lpf - Constraints para Colorlight i9 (ECP5-45F)
# ============================================================

# Reloj de 25 MHz de la placa
LOCATE COMP "clk_25mhz" SITE "P3";
IOBUF PORT "clk_25mhz" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk_25mhz" 25 MHZ;

# LED de la placa (activo en bajo en la i9)
LOCATE COMP "led_status" SITE "L2";
IOBUF PORT "led_status" IO_TYPE=LVCMOS33;

# Salida de datos hacia la matriz WS2812
# NOTA: ajusta este pin segun el conector/breakout que uses.
# K18 es un IO tipico expuesto en las placas de expansion de la i9.
LOCATE COMP "ws2812_din" SITE "E5";
IOBUF PORT "ws2812_din" IO_TYPE=LVCMOS33 DRIVE=8;
